# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/smart_travel

# Supabase Auth (JWT verification via JWKS)
SUPABASE_JWT_JWKS_URL=https://[ref].supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_ISSUER=https://[ref].supabase.co/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_ANON_KEY=<your anon key>
SUPABASE_SERVICE_ROLE_KEY=<your service role key>

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Weather
WEATHER_API_URL=https://api.open-meteo.com/v1/forecast

# Webhook
WEBHOOK_URL=https://discord.com/api/webhooks/...

# App
LOG_LEVEL=INFO

# Agent Models
HAIKU_MODEL=claude-haiku-4-5-20251001
SONNET_MODEL=claude-sonnet-4-6
EMBEDDING_MODEL=all-MiniLM-L6-v2

# LangSmith / LangGraph tracing
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=smart-travel-planner

# Agent runtime
MAX_AGENT_STEPS=8
TOOL_ARG_REPAIR_ATTEMPTS=1
ANTHROPIC_TIMEOUT_SECONDS=30

# CORS
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]